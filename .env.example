# Paystack keys
PAYSTACK_SECRET_KEY_TEST=sk_test_your_test_secret_key
PAYSTACK_PUBLIC_KEY_TEST=pk_test_your_test_public_key

PAYSTACK_SECRET_KEY_LIVE=sk_live_your_live_secret_key
PAYSTACK_PUBLIC_KEY_LIVE=pk_live_your_live_public_key

# Set mode to test or live
PAYSTACK_MODE=live

# Optional callback URL if you want a custom return page
# CALLBACK_URL=https://yourdomain.com/Ink.html

# JWT secret used for auth token signing
JWT_SECRET=replace-with-a-secure-secret

PORT=3000
